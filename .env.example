# Copy to .env and fill in — EvalForge is bring-your-own-key.
# Any OpenAI-compatible endpoint works (OpenAI, Groq, Together, local vLLM/Ollama…).

# --- OpenAI (default) ---
OPENAI_API_KEY=sk-...
JUDGE_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=            # leave unset for OpenAI

# --- Groq (OpenAI-compatible) — uncomment to use instead ---
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# JUDGE_MODEL=llama-3.3-70b-versatile

# --- Metric selection (optional) — trim to cut cost/latency ---
# Comma-separated subsets. Unset = all. Rows with a `context` use RAG metrics;
# rows without use LLM metrics. Dropping a metric skips its judge calls.
# LLM metrics: correctness, relevance, completeness, conciseness
# LLM_METRICS=correctness,relevance
# RAG metrics: faithfulness, context_recall, context_precision, answer_relevancy
# RAG_METRICS=faithfulness,answer_relevancy
